@page
@model LibraryManagement.Pages.Books.Edit
<h2>Edit Book</h2>

@if(!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <input type="hidden" asp-for="Id"/>

    <div class="row mb-3">
        <label class="col-sm-4">Title</label>
        <div class="col-sm-8">
            <input class="form-control" asp-for="Title" />
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-4">Author</label>
        <div class="col-sm-8">
            <input class="form-control" asp-for="Author" />
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-4">Genre</label>
        <div class="col-sm-8">
            <input class="form-control" asp-for="Genre" />
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-4">Price</label>
        <div class="col-sm-8">
            <input class="form-control" asp-for="Price" type="number" step="0.01" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-page="/Books/Index" class="btn btn-secondary">Cancel</a>
</form>